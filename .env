# ─── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=a6909f9db3a6031b5fe26499a7f5a075916444ddaa34a84a992261293a27bb6a
FLASK_ENV=development
FLASK_DEBUG=1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///ipedg.db

# ─── MailHog ──────────────────────────────────────────────────────────────────
MAILHOG_SMTP_HOST=localhost
MAILHOG_SMTP_PORT=1025
MAILHOG_API_HOST=localhost
MAILHOG_API_PORT=8025

# ─── Mail Domain ──────────────────────────────────────────────────────────────
MAIL_DOMAIN=ipedg.local

# ─── VirusTotal (optional – get free key at virustotal.com) ───────────────────
VIRUSTOTAL_API_KEY=678a19f0c206a6c3b4789b95bd50dd5bf4c7f57421b23e8533a00c0d8275ba66

# ─── Nmap (optional) ──────────────────────────────────────────────────────────
NMAP_PATH=C:\Program Files (x86)\Nmap\nmap.exe

# ─── Packet Capture (optional – requires Wireshark + admin) ──────────────────
ENABLE_CAPTURE=1
CAPTURE_INTERFACE=auto

# ─── Scheduler ────────────────────────────────────────────────────────────────
FETCH_INTERVAL_SECONDS=30
QUARANTINE_TTL_DAYS=30

# ─── Dataset ──────────────────────────────────────────────────────────────────
PHISHING_DATASET_PATH=data/phishing_dataset.csv
PHISHING_SUPPLEMENTARY_DATASET=data/CEAS_08.csv

# ─── Admin bootstrap ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@ipedg.local
ADMIN_PASSWORD=Admin@123

# ─── Security ─────────────────────────────────────────────────────────────────
SESSION_COOKIE_SECURE=0
WTF_CSRF_ENABLED=1
MAX_CONTENT_LENGTH_MB=16
